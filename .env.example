# Environment Variables Template
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the real `.env` file to GitHub!

# Firebase Configuration
# Get these from: Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Paymob Configuration (Optional - for payment features)
# Get these from: Paymob Dashboard > Settings
VITE_PAYMOB_API_KEY=your_paymob_api_key
VITE_PAYMOB_INTEGRATION_ID_CARD=your_paymob_integration_id_for_card
VITE_PAYMOB_INTEGRATION_ID_WALLET=your_paymob_integration_id_for_wallet
VITE_PAYMOB_IFRAME_ID=your_paymob_iframe_id
